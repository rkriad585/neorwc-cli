{
  "name": "neorwc",
  "version": "1.0.0",
  "description": "Neorwc: AI-powered documentation suite (Bun + TypeScript)",
  "type": "module",
  "module": "neorwc.ts",
  "bin": {
    "neorwc": "./neorwc.ts"
  },
  "scripts": {
    "dev": "bun run neorwc.ts",
    "build": "bun build --compile --target=bun-windows-x64 ./neorwc.ts --outfile dist/neorwc",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./neorwc.ts --outfile dist/neorwc-linux",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 ./neorwc.ts --outfile dist/neorwc-mac"
  },
  "keywords": ["documentation", "ai", "cli"],
  "author": "RK Riad Khan",
  "license": "ISC",
  "dependencies": {
    "citty": "^0.2.2",
    "cli-spinners": "^3.4.0",
    "listr2": "^10.2.1",
    "modelpedia": "^0.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
